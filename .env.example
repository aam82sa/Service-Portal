# Copy to .env.local and fill in from Supabase Dashboard -> Settings -> API
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY
# dev = seeded email/password test users; sso = Entra ID via Supabase Auth
# 'dev' enables password sign-in against the seeded matrix (local stacks only).
# Unset or anything else fails closed to Entra ID SSO.
VITE_AUTH_MODE=dev
# Optional: passcode curtain for test deployments
VITE_SITE_PASSCODE=
